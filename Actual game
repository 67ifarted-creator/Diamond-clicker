        ];

        // Achievements
        const achievements = [
            { id: 'first', name: '🌟 First Step', description: 'Earn your first diamond', condition: () => gameState.diamonds >= 1 },
            { id: 'ten', name: '👶 Baby Steps', description: 'Earn 10 diamonds', condition: () => gameState.totalDiamondsEarned >= 10 },
            { id: 'hundred', name: '💯 Century', description: 'Earn 100 diamonds', condition: () => gameState.totalDiamondsEarned >= 100 },
            { id: 'thousand', name: '🎯 Thousand', description: 'Earn 1,000 diamonds', condition: () => gameState.totalDiamondsEarned >= 1000 },
            { id: 'tenk', name: '💰 Riches', description: 'Earn 10,000 diamonds', condition: () => gameState.totalDiamondsEarned >= 10000 },
            { id: 'hundredk', name: '🤑 Wealthy', description: 'Earn 100,000 diamonds', condition: () => gameState.totalDiamondsEarned >= 100000 },
            { id: 'million', name: '💎 Millionaire', description: 'Earn 1,000,000 diamonds', condition: () => gameState.totalDiamondsEarned >= 1000000 },
            { id: 'billion', name: '🚀 Billionaire', description: 'Earn 1,000,000,000 diamonds', condition: () => gameState.totalDiamondsEarned >= 1000000000 },
            { id: 'trillion', name: '🌌 Trillionaire', description: 'Earn 1,000,000,000,000 diamonds', condition: () => gameState.totalDiamondsEarned >= 1000000000000 },
            
            { id: 'first-building', name: '🏗️ Builder', description: 'Buy your first building', condition: () => buildings.some(b => b.owned > 0) },
            { id: 'five-buildings', name: '🏢 Contractor', description: 'Buy 5 different buildings', condition: () => buildings.filter(b => b.owned > 0).length >= 5 },
            { id: 'all-buildings', name: '🌆 Metropolis', description: 'Buy all buildings', condition: () => buildings.filter(b => b.owned > 0).length === buildings.length },
            { id: 'ten-owned', name: '📈 Growing', description: 'Own 10 total buildings', condition: () => buildings.reduce((sum, b) => sum + b.owned, 0) >= 10 },
            { id: 'hundred-owned', name: '🏭 Industrial', description: 'Own 100 total buildings', condition: () => buildings.reduce((sum, b) => sum + b.owned, 0) >= 100 },
            { id: 'thousand-owned', name: '🌍 Dominion', description: 'Own 1,000 total buildings', condition: () => buildings.reduce((sum, b) => sum + b.owned, 0) >= 1000 },
            
            { id: 'first-upgrade', name: '⚡ Enhanced', description: 'Buy your first upgrade', condition: () => upgrades.some(u => u.purchased) },
            { id: 'five-upgrades', name: '⚙️ Advanced Tech', description: 'Buy 5 upgrades', condition: () => upgrades.filter(u => u.purchased).length >= 5 },
            { id: 'ten-upgrades', name: '🔮 Tech Master', description: 'Buy 10 upgrades', condition: () => upgrades.filter(u => u.purchased).length >= 10 },
            { id: 'all-upgrades', name: '🌟 Ultimate Power', description: 'Buy all upgrades', condition: () => upgrades.filter(u => u.purchased).length === upgrades.length },
            
            { id: 'ten-clicks', name: '🖱️ Clicker', description: 'Make 10 clicks', condition: () => gameState.clicksPerformed >= 10 },
            { id: 'hundred-clicks', name: '⚡ Rapid Fire', description: 'Make 100 clicks', condition: () => gameState.clicksPerformed >= 100 },
            { id: 'thousand-clicks', name: '🎮 Speedrunner', description: 'Make 1,000 clicks', condition: () => gameState.clicksPerformed >= 1000 },
            { id: 'tenk-clicks', name: '💪 Muscle Memory', description: 'Make 10,000 clicks', condition: () => gameState.clicksPerformed >= 10000 },
            
            { id: 'prestige', name: '✨ First Ascension', description: 'Transcend once', condition: () => gameState.prestigePoints > 0 },
            { id: 'prestige-5', name: '💫 Enlightened', description: 'Reach 5 prestige points', condition: () => gameState.prestigePoints >= 5 },
            { id: 'prestige-25', name: '🌠 Transcendent', description: 'Reach 25 prestige points', condition: () => gameState.prestigePoints >= 25 },
            { id: 'prestige-100', name: '👑 Divine', description: 'Reach 100 prestige points', condition: () => gameState.prestigePoints >= 100 },
            
            { id: 'special', name: '🎲 Lucky Strike', description: 'Click a lucky diamond event', condition: () => gameState.specialEventsClicked > 0 },
            { id: 'special-5', name: '🍀 Fortune Seeker', description: 'Click 5 lucky diamond events', condition: () => gameState.specialEventsClicked >= 5 },
            { id: 'special-25', name: '⭐ Luckiest', description: 'Click 25 lucky diamond events', condition: () => gameState.specialEventsClicked >= 25 },
        ];

        let earnedAchievements = [];
        let currentUpgradeFilter = 'All';
        let leaderboardFilter = 'diamonds';
        let leaderboardData = [];
        let chatMessages = [];

        // Email Functions
        function setEmail() {
            const email = document.getElementById('emailInput').value.trim();
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

            if (!email) {
                document.getElementById('emailStatus').textContent = 'No email set';
                document.getElementById('emailStatus').classList.remove('verified');
                gameState.email = '';
                gameState.emailVerified = false;
                return;
            }

            if (!emailRegex.test(email)) {
                document.getElementById('emailStatus').textContent = '❌ Invalid email format';
                return;
            }

            gameState.email = email;
            gameState.emailVerified = true;
            document.getElementById('emailStatus').textContent = '✓ Email verified: ' + email;
            document.getElementById('emailStatus').classList.add('verified');
            document.getElementById('emailInput').value = email;

            // Store email in localStorage
            localStorage.setItem('diamondClickerEmail', JSON.stringify({
                email: email,
                addedDate: new Date().toISOString()
            }));
        }

        // Chat Functions
        function sendChatMessage() {
            const input = document.getElementById('chatInput');
            const message = input.value.trim();

            if (!message) return;
            if (gameState.playerName === 'Anonymous') {
                alert('Please set your name first!');
                return;
            }

            const chatMessage = {
                author: gameState.playerName,
                email: gameState.emailVerified ? gameState.email : null,
                message: message,
                timestamp: new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' })
            };

            chatMessages.push(chatMessage);
            
            // Keep only last 50 messages
            if (chatMessages.length > 50) {
                chatMessages.shift();
            }

            input.value = '';
            renderChat();
            
            // Auto-scroll to bottom
            const chatContainer = document.getElementById('chatMessages');
            chatContainer.scrollTop = chatContainer.scrollHeight;

            // Save to localStorage
            localStorage.setItem('diamondClickerChat', JSON.stringify(chatMessages));
        }

        function handleChatKeypress(event) {
            if (event.key === 'Enter') {
                sendChatMessage();
            }
        }

        function renderChat() {
            const container = document.getElementById('chatMessages');
            container.innerHTML = '';

            chatMessages.forEach(msg => {
                const div = document.createElement('div');
                div.className = 'chat-message';
                
                div.innerHTML = `
                    <div class="chat-author">${msg.author} ${msg.email ? '📧' : ''}</div>
                    <div class="chat-text">${escapeHtml(msg.message)}</div>
                    <div class="chat-time">${msg.timestamp}</div>
                `;

                container.appendChild(div);
            });

            // Show system message if no messages
            if (chatMessages.length === 0) {
                const div = document.createElement('div');
                div.className = 'chat-message system';
                div.innerHTML = '<div class="chat-text">No messages yet. Be the first to chat!</div>';
                container.appendChild(div);
            }
        }

        function escapeHtml(text) {
            const map = {
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                '"': '&quot;',
                "'": '&#039;'
            };
            return text.replace(/[&<>"']/g, m => map[m]);
        }

        // Leaderboard Functions
        function setPlayerName() {
            const name = document.getElementById('playerNameInput').value.trim();
            if (name) {
                gameState.playerName = name;
                document.getElementById('playerNameDisplay').textContent = name;
                updateLeaderboard();
                addChatSystemMessage(`${name} joined the game!`);
            }
        }

        function addChatSystemMessage(text) {
            const chatMessage = {
                author: 'SYSTEM',
                message: text,
                timestamp: new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }),
                isSystem: true
            };
            chatMessages.push(chatMessage);
            if (chatMessages.length > 50) {
                chatMessages.shift();
            }
            renderChat();
        }

        function updateLeaderboard() {
            let saved = localStorage.getItem('diamondClickerLeaderboard');
            leaderboardData = saved ? JSON.parse(saved) : [];

            let playerIndex = leaderboardData.findIndex(p => p.name === gameState.playerName);
            
            if (playerIndex !== -1) {
                if (gameState.totalDiamondsEarned > leaderboardData[playerIndex].score) {
                    leaderboardData[playerIndex] = {
                        name: gameState.playerName,
                        score: gameState.totalDiamondsEarned,
                        prestige: gameState.prestigePoints,
                        buildings: buildings.reduce((sum, b) => sum + b.owned, 0),
                        email: gameState.emailVerified ? gameState.email : null,
                        date: new Date().toLocaleString()
                    };
                }
            } else {
                leaderboardData.push({
                    name: gameState.playerName,
                    score: gameState.totalDiamondsEarned,
                    prestige: gameState.prestigePoints,
                    buildings: buildings.reduce((sum, b) => sum + b.owned, 0),
                    email: gameState.emailVerified ? gameState.email : null,
                    date: new Date().toLocaleString()
                });
            }

            localStorage.setItem('diamondClickerLeaderboard', JSON.stringify(leaderboardData));
            renderLeaderboard();
        }

        function filterLeaderboard(type) {
            leaderboardFilter = type;
            document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
            renderLeaderboard();
        }

        function renderLeaderboard() {
            const container = document.getElementById('leaderboardContainer');
            container.innerHTML = '';

            let sorted = [...leaderboardData];
            if (leaderboardFilter === 'diamonds') {
                sorted.sort((a, b) => b.score - a.score);
            } else if (leaderboardFilter === 'prestige') {
                sorted.sort((a, b) => b.prestige - a.prestige);
            } else if (leaderboardFilter === 'buildings') {
                sorted.sort((a, b) => b.buildings - a.buildings);
            }

            sorted.slice(0, 10).forEach((player, index) => {
                const isCurrentPlayer = player.name === gameState.playerName;
                const div = document.createElement('div');
                div.className = `leaderboard-entry ${isCurrentPlayer ? 'you' : ''}`;

                let score = '';
                if (leaderboardFilter === 'diamonds') {
                    score = formatNumber(player.score) + ' 💎';
                } else if (leaderboardFilter === 'prestige') {
                    score = player.prestige + ' ✨';
                } else if (leaderboardFilter === 'buildings') {
                    score = player.buildings + ' 🏭';
                }

                div.innerHTML = `
                    <div class="leaderboard-rank">#${index + 1}</div>
                    <div class="leaderboard-info">
                        <div class="leaderboard-name">${player.name} ${player.email ? '📧' : ''} ${isCurrentPlayer ? '👈 YOU' : ''}</div>
                        <div class="leaderboard-score">${score}</div>
                    </div>
                `;

                container.appendChild(div);
            });

            if (leaderboardData.length === 0) {
                const div = document.createElement('div');
                div.style.textAlign = 'center';
                div.style.color = '#90caf9';
                div.style.padding = '20px';
                div.innerHTML = 'No leaderboard data yet. Set your name to join!';
                container.appendChild(div);
            }
        }

        // Utility Functions
        function formatNumber(num) {
            if (num >= 1e15) return (num / 1e15).toFixed(2) + 'Q';
            if (num >= 1e12) return (num / 1e12).toFixed(2) + 'T';
            if (num >= 1e9) return (num / 1e9).toFixed(2) + 'B';
            if (num >= 1e6) return (num / 1e6).toFixed(2) + 'M';
            if (num >= 1e3) return (num / 1e3).toFixed(2) + 'K';
            return Math.floor(num).toString();
        }

        function getPrestigeReward() {
            return Math.floor(Math.sqrt(gameState.totalDiamondsEarned / 1e6));
        }

        function getBuildingCost(building) {
            return Math.floor(building.baseCost * Math.pow(1.15, building.owned));
        }

        function getClickPower() {
            let power = 1 + gameState.clickPower;
            upgrades.forEach(u => {
                if (u.type === 'click' && u.purchased) {
                    power += u.effect;
                }
            });
            return power;
        }

        function calculateDPS() {
            let dps = 0;
            buildings.forEach(building => {
                let production = building.baseProduction * building.owned;
                
                upgrades.forEach(u => {
                    if (u.purchased) {
                        if (u.type === building.id.replace(/\d+/, '')) {
                            production *= u.effect;
                        }
                        if (u.type === 'all') {
                            production *= u.effect;
                        }
                        if (u.type === 'passive' && u.id === 'passive1') {
                            production *= u.effect;
                        }
                    }
                });
                dps += production;
            });
            return dps * gameState.multiplier;
        }

        // Click Handler
        function clickDiamond() {
            const power = getClickPower();
            gameState.diamonds += power;
            gameState.totalDiamondsEarned += power;
            gameState.clicksPerformed += 1;
            updateDisplay();
            createClickEffect(event, power);
            checkAchievements();
            updateLeaderboard();
        }

        function createClickEffect(e, amount) {
            const effect = document.createElement('div');
            effect.className = 'click-effect';
            effect.textContent = '+' + formatNumber(amount);
            effect.style.left = (e.clientX || e.touches?.[0].clientX) + 'px';
            effect.style.top = (e.clientY || e.touches?.[0].clientY) + 'px';
            document.body.appendChild(effect);
            setTimeout(() => effect.remove(), 1000);
        }

        // Building Functions
        function buyBuilding(id) {
            const building = buildings.find(b => b.id === id);
            const cost = getBuildingCost(building);

            if (gameState.diamonds >= cost) {
                gameState.diamonds -= cost;
                building.owned += 1;
                gameState.buildingsOwned += 1;
                gameState.diamondsPerSecond = calculateDPS();
                updateDisplay();
                renderBuildings();
                checkAchievements();
                updateLeaderboard();
            }
        }

        function renderBuildings() {
            const container = document.getElementById('buildingsContainer');
            container.innerHTML = '';

            buildings.forEach(building => {
                const cost = getBuildingCost(building);
                const canAfford = gameState.diamonds >= cost;
                const div = document.createElement('div');
                div.className = `building ${canAfford ? '' : 'disabled'}`;
                div.onclick = () => buyBuilding(building.id);

                div.innerHTML = `
                    <div class="building-name">${building.name}</div>
                    <div class="building-cost">Cost: ${formatNumber(cost)} 💎</div>
                    <div class="building-effect">+${formatNumber(building.baseProduction)}/s each</div>
                    ${building.owned > 0 ? `<span class="building-owned">×${building.owned}</span>` : ''}
                `;

                container.appendChild(div);
            });
        }

        // Upgrade Functions
        function getUpgradeCategories() {
            const categories = [...new Set(upgrades.map(u => u.category))];
            return ['All', ...categories];
        }

        function renderUpgradeTabs() {
            const container = document.getElementById('upgradeTabs');
            container.innerHTML = '';
            const categories = getUpgradeCategories();

            categories.forEach(cat => {
                const btn = document.createElement('button');
                btn.className = `tab-button ${cat === currentUpgradeFilter ? 'active' : ''}`;
                btn.textContent = cat;
                btn.onclick = () => {
                    currentUpgradeFilter = cat;
                    renderUpgradeTabs();
                    renderUpgrades();
                };
                container.appendChild(btn);
            });
        }

        function buyUpgrade(id) {
            const upgrade = upgrades.find(u => u.id === id);
            if (!upgrade.purchased && gameState.diamonds >= upgrade.cost) {
                gameState.diamonds -= upgrade.cost;
                upgrade.purchased = true;
                gameState.diamondsPerSecond = calculateDPS();
                updateDisplay();
                renderUpgrades();
                checkAchievements();
                updateLeaderboard();
            }
        }

        function renderUpgrades() {
            const container = document.getElementById('upgradesContainer');
            container.innerHTML = '';

            let filteredUpgrades = upgrades;
            if (currentUpgradeFilter !== 'All') {
                filteredUpgrades = upgrades.filter(u => u.category === currentUpgradeFilter);
            }

            filteredUpgrades.forEach(upgrade => {
                const div = document.createElement('div');
                div.className = `upgrade ${upgrade.purchased ? 'purchased' : gameState.diamonds >= upgrade.cost ? '' : 'disabled'}`;
                div.onclick = () => buyUpgrade(upgrade.id);

                div.innerHTML = `
                    <div class="upgrade-name">${upgrade.name} ${upgrade.purchased ? '✓' : ''}</div>
                    <div class="upgrade-cost">${upgrade.purchased ? 'Owned' : 'Cost: ' + formatNumber(upgrade.cost)}</div>
                `;

                container.appendChild(div);
            });
        }

        // Special Events
        function triggerSpecialEvent() {
            if (!gameState.specialEventActive) {
                gameState.specialEventActive = true;
                gameState.specialEventMultiplier = Math.random() < 0.5 ? 2 : 7;
                
                const container = document.getElementById('specialEventContainer');
                const event = document.createElement('div');
                event.className = 'special-event';
                event.innerHTML = `
                    <div class="special-event-icon">✨</div>
                    <div>Lucky Diamond! Click for ${gameState.specialEventMultiplier}x boost!</div>
                `;
                event.onclick = () => {
                    gameState.diamonds += 50 * gameState.specialEventMultiplier;
                    gameState.totalDiamondsEarned += 50 * gameState.specialEventMultiplier;
                    gameState.specialEventsClicked += 1;
                    gameState.specialEventActive = false;
                    event.remove();
                    updateDisplay();
                    checkAchievements();
                    updateLeaderboard();
                };
                container.appendChild(event);

                setTimeout(() => {
                    if (gameState.specialEventActive) {
                        gameState.specialEventActive = false;
                        event.remove();
                    }
                }, 8000);
            }
        }

        // Prestige/Transcend
        function transcend() {
            const prestigeGain = getPrestigeReward();
            if (prestigeGain > 0) {
                gameState.prestigePoints += prestigeGain;
                gameState.multiplier = 1 + (gameState.prestigePoints * 0.01);
                
                buildings.forEach(b => b.owned = 0);
                upgrades.forEach(u => u.purchased = false);
                gameState.diamonds = 0;
                gameState.diamondsPerSecond = 0;
                gameState.clickPower = 1;
                gameState.buildingsOwned = 0;
                
                addChatSystemMessage(`${gameState.playerName} transcended to the next level!`);
                
                updateDisplay();
                renderBuildings();
                renderUpgrades();
                checkAchievements();
                updateLeaderboard();
            }
        }

        // Achievement System
        function checkAchievements() {
            achievements.forEach(ach => {
                if (!earnedAchievements.includes(ach.id) && ach.condition()) {
                    earnedAchievements.push(ach.id);
                    renderAchievements();
                }
            });
        }

        function renderAchievements() {
            const container = document.getElementById('achievementsContainer');
            container.innerHTML = '';

            achievements.forEach(ach => {
                const earned = earnedAchievements.includes(ach.id);
                const div = document.createElement('div');
                div.className = `achievement ${earned ? '' : 'locked'}`;
                div.title = ach.description;
                div.innerHTML = `${ach.name}`;
                container.appendChild(div);
            });
        }

        // Update Display
        function updateDisplay() {
            gameState.diamondsPerSecond = calculateDPS();
            
            document.getElementById('diamondCount').textContent = formatNumber(gameState.diamonds);
            document.getElementById('prestigeCount').textContent = gameState.prestigePoints;
            document.getElementById('multiplierValue').textContent = gameState.multiplier.toFixed(2) + 'x';
            document.getElementById('clickPowerValue').textContent = formatNumber(getClickPower());
            document.getElementById('clickAmount').textContent = '+' + formatNumber(getClickPower());
            document.getElementById('dpsDisplay').textContent = `Diamonds per second: ${formatNumber(gameState.diamondsPerSecond)}`;
            
            document.getElementById('transcendReward').textContent = `You will gain: ${getPrestigeReward()} prestige points`;
            
            const canTranscend = getPrestigeReward() > 0;
            document.getElementById('transcendButton').classList.toggle('disabled', !canTranscend);

            document.getElementById('totalEarned').textContent = formatNumber(gameState.totalDiamondsEarned);
            document.getElementById('totalClicks').textContent = gameState.clicksPerformed;
            document.getElementById('buildingsOwnedStat').textContent = buildings.reduce((sum, b) => sum + b.owned, 0);
            document.getElementById('upgradesPurchasedStat').textContent = upgrades.filter(u => u.purchased).length;
            document.getElementById('specialEventsClicledStat').textContent = gameState.specialEventsClicked;
        }

        // Reset Functions
        function resetAllData() {
            if (confirm('Reset ALL progress? This includes prestige points!')) {
                gameState = {
                    diamonds: 0,
                    prestigePoints: 0,
                    totalDiamondsEarned: 0,
                    clickPower: 1,
                    diamondsPerSecond: 0,
                    multiplier: 1,
                    lastClickTime: 0,
                    specialEventActive: false,
                    specialEventMultiplier: 1,
                    clicksPerformed: 0,
                    specialEventsClicked: 0,
                    buildingsOwned: 0,
                    playerName: 'Anonymous',
                    email: '',
                    emailVerified: false
                };
                buildings.forEach(b => b.owned = 0);
                upgrades.forEach(u => u.purchased = false);
                earnedAchievements = [];
                document.getElementById('playerNameDisplay').textContent = 'Anonymous';
                updateDisplay();
                renderBuildings();
                renderUpgrades();
                renderAchievements();
            }
        }

        // Game Loop
        setInterval(() => {
            gameState.diamonds += gameState.diamondsPerSecond / 10;
            gameState.totalDiamondsEarned += gameState.diamondsPerSecond / 10;
            updateDisplay();
            checkAchievements();
            updateLeaderboard();
        }, 100);

        // Trigger random special events
        setInterval(() => {
            if (Math.random() < 0.001) {
                triggerSpecialEvent();
            }
        }, 1000);

        // Initialize
        window.addEventListener('load', () => {
            renderUpgradeTabs();
            renderBuildings();
            renderUpgrades();
            renderAchievements();
            updateDisplay();
            renderLeaderboard();
            renderChat();

            // Load email data
            const savedEmail = localStorage.getItem('diamondClickerEmail');
            if (savedEmail) {
                const data = JSON.parse(savedEmail);
                gameState.email = data.email;
                gameState.emailVerified = true;
                document.getElementById('emailInput').value = data.email;
                document.getElementById('emailStatus').textContent = '✓ Email verified: ' + data.email;
                document.getElementById('emailStatus').classList.add('verified');
            }

            // Load chat data
            const savedChat = localStorage.getItem('diamondClickerChat');
            if (savedChat) {
                chatMessages = JSON.parse(savedChat);
                renderChat();
            }
        });

        // Save game data periodically
        setInterval(() => {
            localStorage.setItem('diamondClickerState', JSON.stringify({
                gameState,
                buildings,
                upgrades,
                earnedAchievements
            }));
        }, 5000);

        // Load saved data
        window.addEventListener('load', () => {
            const saved = localStorage.getItem('diamondClickerState');
            if (saved) {
                const data = JSON.parse(saved);
                Object.assign(gameState, data.gameState);
                buildings.forEach((b, i) => Object.assign(b, data.buildings[i]));
                upgrades.forEach((u, i) => Object.assign(u, data.upgrades[i]));
                earnedAchievements = data.earnedAchievements;
                document.getElementById('playerNameDisplay').textContent = gameState.playerName;
            }
        });
    </script>
</body>
</html>
