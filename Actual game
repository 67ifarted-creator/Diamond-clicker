<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Diamond Clicker - Incremental Game</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Arial', sans-serif;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
            color: #e0e0e0;
        }

        .main-container {
            display: grid;
            grid-template-columns: 3fr 1.5fr 1.2fr;
            gap: 20px;
            max-width: 1600px;
            width: 100%;
        }

        .game-section {
            background: rgba(20, 20, 40, 0.8);
            border: 2px solid #4a90e2;
            border-radius: 15px;
            padding: 30px;
            backdrop-filter: blur(10px);
        }

        .sidebar {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .leaderboard-section {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .sidebar-card {
            background: rgba(20, 20, 40, 0.8);
            border: 2px solid #4a90e2;
            border-radius: 15px;
            padding: 20px;
            backdrop-filter: blur(10px);
        }

        .leaderboard-card {
            background: rgba(20, 20, 40, 0.8);
            border: 2px solid #ffc107;
            border-radius: 15px;
            padding: 20px;
            backdrop-filter: blur(10px);
        }

        .chat-card {
            background: rgba(20, 20, 40, 0.8);
            border: 2px solid #4ade80;
            border-radius: 15px;
            padding: 20px;
            backdrop-filter: blur(10px);
            display: flex;
            flex-direction: column;
        }

        h1 {
            color: #64b5f6;
            text-align: center;
            margin-bottom: 30px;
            font-size: 2.5em;
            text-shadow: 0 0 20px rgba(100, 181, 246, 0.5);
        }

        h2 {
            color: #64b5f6;
            margin-bottom: 15px;
            font-size: 1.3em;
            border-bottom: 2px solid #4a90e2;
            padding-bottom: 10px;
        }

        .leaderboard-card h2 {
            border-bottom-color: #ffc107;
            color: #ffc107;
        }

        .chat-card h2 {
            border-bottom-color: #4ade80;
            color: #4ade80;
        }

        h3 {
            color: #90caf9;
            margin-bottom: 10px;
            font-size: 1em;
        }

        .stats-container {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            margin-bottom: 30px;
        }

        .stat-box {
            background: rgba(74, 144, 226, 0.1);
            border: 1px solid #4a90e2;
            border-radius: 10px;
            padding: 15px;
            text-align: center;
        }

        .stat-label {
            color: #90caf9;
            font-size: 0.85em;
            margin-bottom: 5px;
        }

        .stat-value {
            color: #64b5f6;
            font-size: 1.5em;
            font-weight: bold;
        }

        .clicker-area {
            text-align: center;
            margin: 40px 0;
        }

        .diamond-button {
            width: 220px;
            height: 220px;
            border-radius: 50%;
            background: linear-gradient(135deg, #4a90e2 0%, #357abd 50%, #1e3a5f 100%);
            border: 8px solid #90caf9;
            font-size: 4em;
            cursor: pointer;
            transition: all 0.1s ease;
            box-shadow: 0 0 30px rgba(74, 144, 226, 0.6), inset -3px -3px 8px rgba(0, 0, 0, 0.5);
            display: inline-block;
            position: relative;
            overflow: hidden;
        }

        .diamond-button:hover {
            transform: scale(1.08);
            box-shadow: 0 0 50px rgba(100, 181, 246, 0.8), inset -3px -3px 8px rgba(0, 0, 0, 0.5);
        }

        .diamond-button:active {
            transform: scale(0.95);
        }

        .click-effect {
            position: fixed;
            font-size: 2em;
            font-weight: bold;
            color: #64b5f6;
            pointer-events: none;
            animation: floatUp 1s ease-out forwards;
            text-shadow: 0 0 10px rgba(100, 181, 246, 0.8);
        }

        @keyframes floatUp {
            0% {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
            100% {
                opacity: 0;
                transform: translateY(-80px) scale(1.5);
            }
        }

        .info-text {
            color: #90caf9;
            font-size: 1.1em;
            margin-top: 20px;
            font-weight: bold;
        }

        .dps-display {
            color: #4ade80;
            font-size: 1.2em;
            margin-top: 15px;
            font-weight: bold;
        }

        .building {
            background: rgba(74, 144, 226, 0.1);
            border: 1px solid #4a90e2;
            border-radius: 8px;
            padding: 12px;
            margin-bottom: 10px;
            cursor: pointer;
            transition: all 0.3s ease;
            text-align: left;
            font-size: 0.9em;
        }

        .building:hover:not(.disabled) {
            background: rgba(100, 181, 246, 0.2);
            border-color: #64b5f6;
            transform: translateX(5px);
            box-shadow: 0 0 15px rgba(74, 144, 226, 0.4);
        }

        .building.disabled {
            opacity: 0.4;
            cursor: not-allowed;
        }

        .building-name {
            font-weight: bold;
            color: #64b5f6;
            margin-bottom: 5px;
        }

        .building-cost {
            color: #90caf9;
            font-size: 0.85em;
        }

        .building-effect {
            color: #4ade80;
            font-size: 0.85em;
            margin-top: 5px;
        }

        .building-owned {
            display: inline-block;
            background: #4a90e2;
            color: #e0e0e0;
            padding: 2px 8px;
            border-radius: 3px;
            font-weight: bold;
            font-size: 0.8em;
            margin-left: 8px;
        }

        .special-event {
            background: rgba(255, 193, 7, 0.2);
            border: 2px solid #ffc107;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 15px;
            color: #ffc107;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s ease;
            animation: pulse 1s ease-in-out infinite;
        }

        .special-event:hover {
            background: rgba(255, 193, 7, 0.3);
            transform: scale(1.02);
        }

        @keyframes pulse {
            0%, 100% { box-shadow: 0 0 10px rgba(255, 193, 7, 0.3); }
            50% { box-shadow: 0 0 20px rgba(255, 193, 7, 0.6); }
        }

        .special-event-icon {
            font-size: 2em;
            margin-bottom: 10px;
        }

        .upgrade {
            background: rgba(74, 144, 226, 0.15);
            border: 1px solid #4a90e2;
            border-radius: 6px;
            padding: 10px;
            margin-bottom: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 0.85em;
        }

        .upgrade:hover:not(.disabled) {
            background: rgba(100, 181, 246, 0.25);
            border-color: #64b5f6;
        }

        .upgrade.disabled {
            opacity: 0.3;
            cursor: not-allowed;
        }

        .upgrade.purchased {
            background: rgba(76, 175, 80, 0.2);
            border-color: #4ade80;
            color: #4ade80;
        }

        .upgrade-name {
            font-weight: bold;
            color: #90caf9;
            margin-bottom: 3px;
        }

        .upgrade-cost {
            color: #90caf9;
            font-size: 0.8em;
        }

        .transcend-section {
            background: rgba(156, 39, 176, 0.1);
            border: 2px solid #9c27b0;
            border-radius: 10px;
            padding: 15px;
            margin-top: 15px;
        }

        .transcend-button {
            background: linear-gradient(135deg, #9c27b0 0%, #6a1b9a 100%);
            color: white;
            border: none;
            padding: 12px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: bold;
            width: 100%;
            transition: all 0.3s ease;
            font-size: 1em;
            margin-top: 10px;
        }

        .transcend-button:hover {
            background: linear-gradient(135deg, #b030cc 0%, #7b1fa2 100%);
            box-shadow: 0 0 20px rgba(156, 39, 176, 0.6);
            transform: scale(1.02);
        }

        .transcend-button.disabled {
            opacity: 0.4;
            cursor: not-allowed;
        }

        .achievement {
            background: rgba(255, 193, 7, 0.15);
            border-left: 3px solid #ffc107;
            padding: 8px;
            margin-bottom: 8px;
            border-radius: 4px;
            font-size: 0.85em;
            color: #ffc107;
        }

        .achievement.locked {
            opacity: 0.3;
            border-left-color: #666;
            color: #999;
        }

        .scroll-container {
            max-height: 400px;
            overflow-y: auto;
            padding-right: 10px;
        }

        .scroll-container::-webkit-scrollbar {
            width: 8px;
        }

        .scroll-container::-webkit-scrollbar-track {
            background: rgba(74, 144, 226, 0.1);
            border-radius: 10px;
        }

        .scroll-container::-webkit-scrollbar-thumb {
            background: #4a90e2;
            border-radius: 10px;
        }

        .scroll-container::-webkit-scrollbar-thumb:hover {
            background: #64b5f6;
        }

        .reset-button {
            background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%);
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: bold;
            width: 100%;
            transition: all 0.3s ease;
        }

        .reset-button:hover {
            background: linear-gradient(135deg, #ef5350 0%, #e53935 100%);
            box-shadow: 0 0 15px rgba(244, 67, 54, 0.4);
        }

        .prestige-info {
            color: #9c27b0;
            font-size: 0.9em;
            margin-bottom: 10px;
            line-height: 1.4;
        }

        .tabs {
            display: flex;
            gap: 5px;
            margin-bottom: 15px;
            flex-wrap: wrap;
            border-bottom: 2px solid #4a90e2;
        }

        .tab-button {
            background: rgba(74, 144, 226, 0.1);
            border: 1px solid #4a90e2;
            color: #90caf9;
            padding: 8px 12px;
            border-radius: 5px;
            cursor: pointer;
            font-size: 0.85em;
            transition: all 0.3s ease;
        }

        .tab-button.active {
            background: #4a90e2;
            color: white;
        }

        .tab-button:hover {
            background: rgba(100, 181, 246, 0.2);
        }

        .leaderboard-entry {
            background: rgba(255, 193, 7, 0.1);
            border: 1px solid #ffc107;
            border-radius: 8px;
            padding: 12px;
            margin-bottom: 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .leaderboard-entry.you {
            background: rgba(76, 175, 80, 0.15);
            border-color: #4ade80;
        }

        .leaderboard-rank {
            font-weight: bold;
            font-size: 1.2em;
            color: #ffc107;
            min-width: 30px;
        }

        .leaderboard-entry.you .leaderboard-rank {
            color: #4ade80;
        }

        .leaderboard-info {
            flex: 1;
            margin: 0 10px;
        }

        .leaderboard-name {
            font-weight: bold;
            color: #64b5f6;
            margin-bottom: 3px;
        }

        .leaderboard-score {
            color: #90caf9;
            font-size: 0.85em;
        }

        .player-input {
            display: flex;
            gap: 10px;
            margin-bottom: 15px;
        }

        .player-input input {
            flex: 1;
            padding: 8px;
            background: rgba(74, 144, 226, 0.1);
            border: 1px solid #4a90e2;
            border-radius: 5px;
            color: #e0e0e0;
            font-size: 0.9em;
        }

        .player-input input:focus {
            outline: none;
            border-color: #64b5f6;
            box-shadow: 0 0 10px rgba(100, 181, 246, 0.3);
        }

        .player-input button {
            background: #4a90e2;
            color: white;
            border: none;
            padding: 8px 15px;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            transition: all 0.3s ease;
        }

        .player-input button:hover {
            background: #64b5f6;
        }

        .leaderboard-filter {
            display: flex;
            gap: 5px;
            margin-bottom: 15px;
            flex-wrap: wrap;
        }

        .filter-btn {
            background: rgba(255, 193, 7, 0.1);
            border: 1px solid #ffc107;
            color: #ffc107;
            padding: 6px 12px;
            border-radius: 5px;
            cursor: pointer;
            font-size: 0.8em;
            transition: all 0.3s ease;
        }

        .filter-btn.active {
            background: #ffc107;
            color: #1a1a2e;
        }

        .filter-btn:hover {
            background: rgba(255, 193, 7, 0.2);
        }

        /* Chat Styles */
        .chat-container {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .chat-messages {
            flex: 1;
            background: rgba(10, 10, 20, 0.5);
            border-radius: 8px;
            padding: 10px;
            margin-bottom: 10px;
            overflow-y: auto;
            max-height: 300px;
            border: 1px solid #4ade80;
        }

        .chat-messages::-webkit-scrollbar {
            width: 6px;
        }

        .chat-messages::-webkit-scrollbar-track {
            background: rgba(74, 180, 128, 0.1);
        }

        .chat-messages::-webkit-scrollbar-thumb {
            background: #4ade80;
            border-radius: 3px;
        }

        .chat-message {
            background: rgba(74, 180, 128, 0.1);
            border-left: 3px solid #4ade80;
            padding: 8px;
            margin-bottom: 8px;
            border-radius: 4px;
            font-size: 0.85em;
        }

        .chat-message.system {
            background: rgba(100, 181, 246, 0.1);
            border-left-color: #64b5f6;
            color: #64b5f6;
            font-style: italic;
        }

        .chat-author {
            font-weight: bold;
            color: #4ade80;
            margin-bottom: 3px;
        }

        .chat-text {
            color: #e0e0e0;
            word-break: break-word;
        }

        .chat-time {
            font-size: 0.75em;
            color: #90caf9;
            margin-top: 3px;
        }

        .chat-input-container {
            display: flex;
            gap: 5px;
        }

        .chat-input-container input {
            flex: 1;
            padding: 8px;
            background: rgba(74, 180, 128, 0.1);
            border: 1px solid #4ade80;
            border-radius: 5px;
            color: #e0e0e0;
            font-size: 0.9em;
        }

        .chat-input-container input:focus {
            outline: none;
            border-color: #90caf9;
            box-shadow: 0 0 10px rgba(74, 180, 128, 0.3);
        }

        .chat-input-container button {
            background: #4ade80;
            color: #1a1a2e;
            border: none;
            padding: 8px 12px;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            transition: all 0.3s ease;
            font-size: 0.9em;
        }

        .chat-input-container button:hover {
            background: #90caf9;
        }

        .email-settings {
            background: rgba(156, 39, 176, 0.1);
            border: 1px solid #9c27b0;
            border-radius: 8px;
            padding: 10px;
            margin-bottom: 10px;
            font-size: 0.85em;
        }

        .email-input {
            display: flex;
            gap: 5px;
            margin-bottom: 8px;
            flex-wrap: wrap;
        }

        .email-input input {
            flex: 1;
            padding: 6px;
            background: rgba(156, 39, 176, 0.1);
            border: 1px solid #9c27b0;
            border-radius: 4px;
            color: #e0e0e0;
            font-size: 0.9em;
            min-width: 150px;
        }

        .email-input input:focus {
            outline: none;
            border-color: #b030cc;
        }

        .email-input button {
            background: #9c27b0;
            color: white;
            border: none;
            padding: 6px 10px;
            border-radius: 4px;
            cursor: pointer;
            font-weight: bold;
            font-size: 0.9em;
        }

        .email-input button:hover {
            background: #b030cc;
        }

        .email-status {
            color: #9c27b0;
            font-size: 0.8em;
        }

        .email-status.verified {
            color: #4ade80;
        }

        @media (max-width: 1400px) {
            .main-container {
                grid-template-columns: 1fr;
            }

            .leaderboard-section {
                grid-template-columns: repeat(2, 1fr);
                flex-direction: row;
                flex-wrap: wrap;
            }
        }

        @media (max-width: 768px) {
            h1 {
                font-size: 1.8em;
            }

            .diamond-button {
                width: 150px;
                height: 150px;
                font-size: 3em;
            }

            .stats-container {
                grid-template-columns: 1fr;
            }

            .main-container {
                grid-template-columns: 1fr;
            }

            .sidebar {
                grid-template-columns: 1fr;
                flex-direction: column;
            }

            .leaderboard-section {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="main-container">
        <!-- Main Game Area -->
        <div class="game-section">
            <h1>💎 Diamond Clicker</h1>

            <div class="stats-container">
                <div class="stat-box">
                    <div class="stat-label">Diamonds</div>
                    <div class="stat-value" id="diamondCount">0</div>
                </div>
                <div class="stat-box">
                    <div class="stat-label">Prestige Points</div>
                    <div class="stat-value" id="prestigeCount">0</div>
                </div>
                <div class="stat-box">
                    <div class="stat-label">Multiplier</div>
                    <div class="stat-value" id="multiplierValue">1x</div>
                </div>
                <div class="stat-box">
                    <div class="stat-label">Click Power</div>
                    <div class="stat-value" id="clickPowerValue">1</div>
                </div>
            </div>

            <div class="clicker-area">
                <button class="diamond-button" id="diamondButton" onclick="clickDiamond()">💎</button>
                <div class="info-text" id="clickAmount">+1</div>
                <div class="dps-display" id="dpsDisplay">Diamonds per second: 0</div>
            </div>

            <div id="specialEventContainer"></div>

            <h2>🏭 Buildings</h2>
            <div class="scroll-container" id="buildingsContainer"></div>
        </div>

        <!-- Sidebar -->
        <div class="sidebar">
            <!-- Upgrades -->
            <div class="sidebar-card">
                <h2>⚡ Upgrades</h2>
                <div class="tabs" id="upgradeTabs"></div>
                <div class="scroll-container" id="upgradesContainer"></div>
            </div>

            <!-- Prestige/Transcend -->
            <div class="sidebar-card">
                <h2>✨ Transcendence</h2>
                <div class="prestige-info" id="prestigeInfo">
                    Transcend to reset your progress but keep prestige points for permanent multipliers!
                </div>
                <div class="transcend-section">
                    <div id="transcendReward">You will gain: 0 prestige points</div>
                    <button class="transcend-button" id="transcendButton" onclick="transcend()">Transcend Now</button>
                </div>
            </div>

            <!-- Achievements -->
            <div class="sidebar-card">
                <h2>🏆 Achievements</h2>
                <div class="scroll-container" id="achievementsContainer"></div>
            </div>

            <button class="reset-button" onclick="resetAllData()">🔄 Full Reset</button>
        </div>

        <!-- Leaderboard & Chat Section -->
        <div class="leaderboard-section">
            <!-- Global Leaderboard -->
            <div class="leaderboard-card">
                <h2>🏆 Global Leaderboard</h2>

                <div class="player-input">
                    <input type="text" id="playerNameInput" placeholder="Enter your name..." maxlength="20">
                    <button onclick="setPlayerName()">Set Name</button>
                </div>

                <div class="leaderboard-filter">
                    <button class="filter-btn active" onclick="filterLeaderboard('diamonds')">💎 Diamonds</button>
                    <button class="filter-btn" onclick="filterLeaderboard('prestige')">✨ Prestige</button>
                    <button class="filter-btn" onclick="filterLeaderboard('buildings')">🏭 Buildings</button>
                </div>

                <div class="scroll-container" id="leaderboardContainer"></div>
            </div>

            <!-- Chat -->
            <div class="chat-card">
                <h2>💬 Global Chat</h2>

                <div class="email-settings">
                    <div style="margin-bottom: 8px; color: #9c27b0;">📧 Email (Optional)</div>
                    <div class="email-input">
                        <input type="email" id="emailInput" placeholder="your@email.com" maxlength="50">
                        <button onclick="setEmail()">Add Email</button>
                    </div>
                    <div class="email-status" id="emailStatus">No email set</div>
                </div>

                <div class="chat-container">
                    <div class="chat-messages" id="chatMessages"></div>
                    
                    <div class="chat-input-container">
                        <input type="text" id="chatInput" placeholder="Say something..." maxlength="100" onkeypress="handleChatKeypress(event)">
                        <button onclick="sendChatMessage()">Send</button>
                    </div>
                </div>
            </div>

            <!-- Statistics -->
            <div class="leaderboard-card">
                <h2>📊 Your Stats</h2>
                <div class="scroll-container">
                    <div class="stat-box" style="text-align: left; margin-bottom: 10px;">
                        <div class="stat-label">Player Name</div>
                        <div class="stat-value" id="playerNameDisplay" style="font-size: 1.2em; color: #90caf9;">Anonymous</div>
                    </div>

                    <div class="stat-box" style="text-align: left; margin-bottom: 10px;">
                        <div class="stat-label">Total Diamonds Earned</div>
                        <div class="stat-value" id="totalEarned" style="font-size: 1.2em; color: #90caf9;">0</div>
                    </div>

                    <div class="stat-box" style="text-align: left; margin-bottom: 10px;">
                        <div class="stat-label">Total Clicks</div>
                        <div class="stat-value" id="totalClicks" style="font-size: 1.2em; color: #90caf9;">0</div>
                    </div>

                    <div class="stat-box" style="text-align: left; margin-bottom: 10px;">
                        <div class="stat-label">Buildings Owned</div>
                        <div class="stat-value" id="buildingsOwnedStat" style="font-size: 1.2em; color: #90caf9;">0</div>
                    </div>

                    <div class="stat-box" style="text-align: left; margin-bottom: 10px;">
                        <div class="stat-label">Upgrades Purchased</div>
                        <div class="stat-value" id="upgradesPurchasedStat" style="font-size: 1.2em; color: #90caf9;">0</div>
                    </div>

                    <div class="stat-box" style="text-align: left; margin-bottom: 10px;">
                        <div class="stat-label">Special Events Clicked</div>
                        <div class="stat-value" id="specialEventsClicledStat" style="font-size: 1.2em; color: #90caf9;">0</div>
